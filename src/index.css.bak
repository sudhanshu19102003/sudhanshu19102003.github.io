@import "tailwindcss";

@theme {
  /* Colors */
  --color-bg: #F5F2EC;
  --color-bg-2: #EDE9E0;
  --color-ink: #1A1916;
  --color-ink-2: #4A4740;
  --color-ink-3: #8A8780;
  --color-accent: #2A4D3C;
  --color-accent-2: #C8A96E;
  --color-line: rgba(26,25,22,0.12);

  /* Font families */
  --font-serif: 'DM Serif Display', serif;
  --font-mono: 'DM Mono', monospace;
  --font-sans: 'Instrument Sans', sans-serif;

  /* Font sizes */
  --font-size-2xs: 10px;
  --font-size-xs: 11px;
  --font-size-sm: 12px;
  --font-size-base: 15px;
  --font-size-lg: 16px;

  /* Letter spacing */
  --tracking-widest: 0.12em;
  --tracking-wider: 0.08em;
  --tracking-wide: 0.06em;

  /* Max widths */
  --max-width-content: 1100px;

  /* Backdrop blur */
  --blur-nav: 12px;
}

/* Base styles */
@layer base {
  *, *::before, *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--color-bg);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
}

/* Component styles with @reference for Tailwind v4 */
@reference "tailwindcss";

/* NAV */
nav {
  @apply fixed top-0 left-0 right-0 z-[100] flex justify-between items-center px-6 py-4 md:px-8 lg:px-12 xl:px-16;
  background: rgba(245, 242, 236, 0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-line);
}

.nav-logo {
  font-family: var(--font-mono);
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-accent);
  letter-spacing: var(--tracking-wide);
}

.nav-links {
  @apply hidden md:flex gap-6 lg:gap-8 list-none;
}

.nav-links a {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  font-weight: 400;
  color: var(--color-ink-2);
  text-decoration: none;
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  transition: color 0.2s;
}

.nav-links a:hover {
  color: var(--color-accent);
}

/* HERO */
.hero {
  @apply pt-20 grid grid-cols-1 lg:grid-cols-2 min-h-[calc(100vh-80px)];
}

.hero-left {
  @apply flex flex-col justify-between px-6 py-12 md:px-8 lg:px-12 xl:px-16;
  border-right: 1px solid var(--color-line);
  min-height: calc(100vh - 80px);
}

@media (max-width: 1023px) {
  .hero-left {
    border-right: none;
    border-bottom: 1px solid var(--color-line);
  }
}

.hero-left-content {
  @apply flex flex-col;
}

.hero-tag {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  letter-spacing: var(--tracking-widest);
  color: var(--color-accent);
  text-transform: uppercase;
  margin-bottom: 1.25rem;
}

.hero-name {
  font-family: var(--font-serif);
  font-size: clamp(2.4rem, 4vw, 3.8rem);
  line-height: 1.06;
  color: var(--color-ink);
  margin-bottom: 1.5rem;
}

.hero-name em {
  font-style: italic;
  color: var(--color-accent);
}

.hero-desc {
  font-size: var(--font-size-lg);
  color: var(--color-ink-2);
  line-height: 1.75;
  max-width: 480px;
  margin-bottom: 2.5rem;
}

.hero-cta {
  @apply flex gap-4 flex-wrap;
}

.btn-primary {
  display: inline-block;
  background: var(--color-accent);
  color: #F5F2EC;
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  padding: 0.75rem 1.75rem;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}

.btn-primary:hover {
  background: #1e3a2c;
  transform: translateY(-1px);
}

.btn-outline {
  display: inline-block;
  background: transparent;
  color: var(--color-ink);
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  padding: 0.75rem 1.75rem;
  text-decoration: none;
  border: 1px solid var(--color-line);
  cursor: pointer;
  transition: border-color 0.2s, transform 0.15s;
}

.btn-outline:hover {
  border-color: var(--color-ink-2);
  transform: translateY(-1px);
}

.hero-right {
  @apply relative flex items-end justify-center p-8 md:p-12 lg:p-16;
  background-color: var(--color-bg);
  background-image:
    linear-gradient(45deg, var(--color-bg-2) 25%, transparent 25%),
    linear-gradient(-45deg, var(--color-bg-2) 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, var(--color-bg-2) 75%),
    linear-gradient(-45deg, transparent 75%, var(--color-bg-2) 75%);
  background-size: 18px 18px;
  background-position: 0 0, 0 9px, 9px -9px, -9px 0;
  min-height: calc(100vh - 80px);
}

@media (max-width: 1023px) {
  .hero-right {
    min-height: 500px;
  }
}

.hero-right-inner {
  @apply flex flex-col gap-4 w-full max-w-2xl;
}

.hero-stats {
  @apply grid grid-cols-4 gap-px;
  background: var(--color-line);
  border: 1px solid var(--color-line);
}

.stat-card {
  background: rgba(245, 242, 236, 0.88);
  backdrop-filter: blur(4px);
  padding: 0.75rem 0.875rem 0.875rem;
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
  position: relative;
}

.stat-label {
  font-family: var(--font-mono);
  font-size: var(--font-size-2xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  align-self: flex-start;
}

.stat-value {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  color: var(--color-ink);
  line-height: 1.2;
  margin-top: 0.25rem;
}

.stat-sublabel {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--color-accent);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  margin-top: 0.125rem;
}

.heatmap-wrap {
  position: relative;
  z-index: 2;
  background: rgba(245, 242, 236, 0.88);
  backdrop-filter: blur(4px);
  border: 1px solid var(--color-line);
  padding: 1.25rem 1.5rem 1.5rem;
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.heatmap-header {
  @apply flex justify-between items-center;
  margin-bottom: 0.85rem;
}

.heatmap-label {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-accent);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
}

.heatmap-total {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wide);
}

.heatmap-svg-wrap {
  @apply w-full;
}

.heatmap-svg-wrap svg {
  display: block;
  width: 100%;
  height: auto;
}

.hm-skeleton {
  width: 100%;
  height: 105px;
  border-radius: 3px;
  background: linear-gradient(90deg, var(--color-bg-2) 25%, var(--color-line) 50%, var(--color-bg-2) 75%);
  background-size: 200% 100%;
  animation: hmShimmer 1.4s ease-in-out infinite;
}

.heatmap-status {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  padding: 0.5rem 0;
}

.hero-location {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wide);
  padding-top: 1rem;
}

.hero-location::before {
  content: '◉ ';
  color: var(--color-accent);
}

/* SECTIONS */
section {
  border-top: 1px solid var(--color-line);
}

.section-inner {
  max-width: var(--max-width-content);
  margin: 0 auto;
  padding: 6rem 4rem;
}

@media (max-width: 768px) {
  .section-inner {
    padding: 4rem 1.5rem;
  }
}

@media (max-width: 1024px) and (min-width: 769px) {
  .section-inner {
    padding: 5rem 2rem;
  }
}

.section-header {
  @apply flex items-baseline gap-4 md:gap-6;
  margin-bottom: 4rem;
}

.section-num {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-accent-2);
  letter-spacing: var(--tracking-wider);
}

.section-title {
  font-family: var(--font-serif);
  font-size: 2rem;
  color: var(--color-ink);
}

/* ABOUT */
.about-grid {
  @apply grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start;
}

.about-text {
  font-size: var(--font-size-lg);
  color: var(--color-ink-2);
  line-height: 1.8;
}

.about-text p + p {
  margin-top: 1.2rem;
}

.about-text strong {
  color: var(--color-ink);
  font-weight: 600;
}

.skills-block {
  @apply flex flex-col gap-5;
}

.skill-cat-name {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-accent);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  margin-bottom: 0.6rem;
}

.skill-tags {
  @apply flex flex-wrap gap-2;
}

.skill-tag {
  font-family: var(--font-mono);
  font-size: var(--font-size-sm);
  color: var(--color-ink-2);
  background: var(--color-bg-2);
  border: 1px solid var(--color-line);
  padding: 0.25rem 0.65rem;
  letter-spacing: 0.02em;
}

/* EXPERIENCE */
.experience-list {
  @apply flex flex-col;
}

.exp-item {
  @apply grid grid-cols-1 md:grid-cols-[200px_1fr] gap-3 md:gap-12 py-8 md:py-10;
  border-bottom: 1px solid var(--color-line);
}

.exp-period {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-accent);
  letter-spacing: var(--tracking-wide);
  margin-bottom: 0.4rem;
}

.exp-company {
  font-family: var(--font-mono);
  font-size: var(--font-size-sm);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wide);
}

.exp-role {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  color: var(--color-ink);
  margin-bottom: 0.75rem;
  line-height: 1.2;
}

.exp-points {
  @apply list-none flex flex-col gap-2;
}

.exp-points li {
  font-size: 14px;
  color: var(--color-ink-2);
  padding-left: 1.2rem;
  position: relative;
}

.exp-points li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--color-accent-2);
  font-size: 12px;
}

/* PROJECTS */
.projects-grid {
  @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px;
  background: var(--color-line);
  border: 1px solid var(--color-line);
}

.project-card {
  background: var(--color-bg);
  padding: 2rem 1.75rem;
  transition: background 0.2s;
  position: relative;
  overflow: hidden;
}

.project-card:hover {
  background: var(--color-bg-2);
}

.project-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--color-accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
}

.project-card:hover::before {
  transform: scaleX(1);
}

.project-card--muted {
  background: var(--color-bg-2);
}

.project-num {
  font-family: var(--font-mono);
  font-size: var(--font-size-2xs);
  color: var(--color-accent-2);
  letter-spacing: var(--tracking-wider);
  margin-bottom: 1rem;
}

.project-num--muted {
  color: var(--color-ink-3);
}

.project-name {
  font-family: var(--font-serif);
  font-size: 1.2rem;
  color: var(--color-ink);
  margin-bottom: 0.75rem;
  line-height: 1.3;
}

.project-name--muted {
  color: var(--color-ink-2);
}

.project-desc {
  font-size: 13px;
  color: var(--color-ink-2);
  line-height: 1.65;
  margin-bottom: 1.25rem;
}

.project-tags {
  @apply flex flex-wrap gap-1;
  margin-bottom: 1rem;
}

.project-tag {
  font-family: var(--font-mono);
  font-size: var(--font-size-2xs);
  color: var(--color-accent);
  background: rgba(42, 77, 60, 0.08);
  border: 1px solid rgba(42, 77, 60, 0.2);
  padding: 0.15rem 0.5rem;
  letter-spacing: var(--tracking-wide);
}

.project-link {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  text-decoration: none;
  letter-spacing: var(--tracking-wide);
  text-transform: uppercase;
  transition: color 0.2s;
}

.project-link:hover {
  color: var(--color-accent);
}

.project-link::after {
  content: ' →';
}

/* RESEARCH */
.research-card {
  @apply grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 lg:gap-12 items-center;
  background: var(--color-accent);
  padding: 3rem;
}

@media (max-width: 1023px) {
  .research-card {
    padding: 2rem;
  }
}

.research-label {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: rgba(245, 242, 236, 0.6);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.research-title {
  font-family: var(--font-serif);
  font-size: 1.6rem;
  color: #F5F2EC;
  line-height: 1.25;
  margin-bottom: 0.75rem;
}

.research-venue {
  font-family: var(--font-mono);
  font-size: var(--font-size-sm);
  color: var(--color-accent-2);
  margin-bottom: 1.25rem;
  letter-spacing: var(--tracking-wide);
}

.research-desc {
  font-size: 14px;
  color: rgba(245, 242, 236, 0.75);
  line-height: 1.7;
}

.research-badge {
  background: rgba(245, 242, 236, 0.1);
  border: 1px solid rgba(245, 242, 236, 0.2);
  padding: 1.5rem;
  text-align: center;
  min-width: 120px;
  align-self: flex-start;
}

@media (max-width: 1023px) {
  .research-badge {
    align-self: auto;
  }
}

.research-badge-text {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  color: #F5F2EC;
  display: block;
}

.research-badge-sub {
  font-family: var(--font-mono);
  font-size: var(--font-size-2xs);
  color: rgba(245, 242, 236, 0.5);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  display: block;
  margin-top: 0.3rem;
}

/* CONTACT */
.contact-grid {
  @apply grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center;
}

.contact-heading {
  font-family: var(--font-serif);
  font-size: 2.5rem;
  color: var(--color-ink);
  line-height: 1.15;
  margin-bottom: 1.5rem;
}

@media (max-width: 768px) {
  .contact-heading {
    font-size: 2rem;
  }
}

.contact-heading em {
  font-style: italic;
  color: var(--color-accent);
}

.contact-sub {
  font-size: var(--font-size-base);
  color: var(--color-ink-2);
  line-height: 1.7;
  margin-bottom: 2rem;
}

.contact-links {
  @apply flex flex-col;
}

.contact-link-item {
  @apply flex items-center justify-between no-underline text-inherit transition-all duration-200;
  padding: 1.1rem 0;
  border-bottom: 1px solid var(--color-line);
}

.contact-link-item:hover {
  padding-left: 0.5rem;
}

.contact-link-label {
  font-family: var(--font-mono);
  font-size: var(--font-size-sm);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
}

.contact-link-value {
  font-size: 14px;
  color: var(--color-ink-2);
}

.contact-link-arrow {
  font-size: var(--font-size-sm);
  color: var(--color-accent);
}

.contact-right {
  @apply flex flex-col gap-4;
}

.cert-section-label {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wider);
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}

.cert-card {
  border: 1px solid var(--color-line);
  padding: 1.25rem 1.5rem;
  background: var(--color-bg-2);
}

.cert-card--light {
  background: var(--color-bg);
}

.cert-title {
  font-size: 14px;
  color: var(--color-ink);
  font-weight: 500;
  margin-bottom: 0.25rem;
}

.cert-issuer {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wide);
}

.cert-id {
  font-family: var(--font-mono);
  font-size: var(--font-size-2xs);
  color: var(--color-accent-2);
  letter-spacing: var(--tracking-wide);
  margin-top: 0.5rem;
}

/* FOOTER */
footer {
  @apply flex flex-col sm:flex-row justify-between items-center gap-2;
  border-top: 1px solid var(--color-line);
  padding: 2rem 4rem;
}

@media (max-width: 640px) {
  footer {
    padding: 1.5rem;
    text-align: center;
  }
}

.footer-copy {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wide);
}

.footer-built {
  font-family: var(--font-mono);
  font-size: var(--font-size-xs);
  color: var(--color-ink-3);
  letter-spacing: var(--tracking-wide);
}

/* KEYFRAMES */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes cellLightUp {
  0%   { opacity: 0; filter: brightness(2.5); }
  30%  { opacity: 0.6; filter: brightness(1.8); }
  100% { opacity: 1; filter: brightness(1); }
}

@keyframes hmShimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.hm-cell {
  opacity: 0;
  animation: cellLightUp 1.1s ease-out forwards;
}

.hero-tag    { animation: fadeUp 0.5s ease both; animation-delay: 0.1s; }
.hero-name   { animation: fadeUp 0.6s ease both; animation-delay: 0.2s; }
.hero-desc   { animation: fadeUp 0.6s ease both; animation-delay: 0.35s; }
.hero-cta    { animation: fadeUp 0.6s ease both; animation-delay: 0.5s; }
